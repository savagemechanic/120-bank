# Postgres database URL from Neon, Supabase, Vercel Postgres, or local Docker.
DATABASE_URL="postgresql://postgres:postgres@localhost:5438/one_twenty_bank"

# Agent credentials. Use long random values in production.
SEIGHA_AGENT_API_KEY="replace-with-seigha-agent-key"
CHIBUEZE_AGENT_API_KEY="replace-with-chibueze-agent-key"

# Human dashboard/review credential. Use a secret review link like:
# https://your-domain.example/?token=<HUMAN_REVIEW_TOKEN>
HUMAN_REVIEW_TOKEN="replace-with-human-review-token"
